{
  "name": "vectrion-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Vectrion - Modular TypeScript-based AI Runtime Infrastructure SDK",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@types/node": "^20.11.24",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "zod": "^3.22.4",
    "tsup": "^8.0.2",
    "pino": "^8.19.0"
  },
  "packageManager": "pnpm@8.15.4"
}
